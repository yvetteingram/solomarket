# Required: Google Gemini API key for AI features (VITE_ prefix needed for browser access)
VITE_GEMINI_API_KEY=

# Required: Supabase project URL
SUPABASE_URL=

# Required: Supabase anonymous key (safe for browser)
VITE_SUPABASE_ANON_KEY=

# Required: Supabase service role key (SERVER ONLY — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=
